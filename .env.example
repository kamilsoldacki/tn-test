# Lokalny serwer tokenów (npm run dev)
XI_API_KEY=
# AGENT_ID= / BRANCH_ID= — server/token-server.mjs
# TTS w dev korzysta z POST /api/tts (wymaga XI_API_KEY powyżej)

# GitHub Pages: dodaj secret VITE_XI_API_KEY w repo (Settings → Secrets and variables → Actions).
# Klucz trafi do bundla JS — każdy odwiedzający stronę może go wyciągnąć z DevTools. Tylko do wewnętrznych testów.

# VITE_BASE_PATH=/  — preview buildu pod ścieżką repo

# VITE_DEV_USE_TOKEN_SERVER=false — dev bez /api/token (jak produkcja)

# Na GitHub Pages domyślnie: WebSocket + agentId (jak pjatk-march_workshops). Wymuś WebRTC + token z branch:
# VITE_PAGES_FORCE_WEBRTC=true
# VITE_BRANCH_ID=agtbrch_9101kt6de3cefmz8yg7jbfq2g726

# VITE_BRANCH_ID=false — bez branch_id w URL tokena
# VITE_USE_WEBSOCKET=true / VITE_USE_AGENT_ID_ONLY=true — tryby awaryjne
